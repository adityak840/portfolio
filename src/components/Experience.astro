---
import Section from "./Section.astro";
import type { ExperienceProps } from "@types";

interface Props {
  experience: ExperienceProps[];
}

const { experience } = Astro.props;

const experienceItems = experience.map((item, index) => ({
  ...item,
  displayIndex: `#${String(index + 1).padStart(2, "0")}`,
  blocks: (Array.isArray(item.summary) ? item.summary : [item.summary]).flatMap(
    (summaryItem) => {
      if (typeof summaryItem === "string") {
        return [
          {
            text: summaryItem,
            itemClass: "flex items-start gap-3 text-sm leading-7 text-white/58",
            dotClass: "mt-2.5 h-1.5 w-1.5 shrink-0 rounded-full bg-primary/80",
          },
        ];
      }

      return [
        {
          text: summaryItem.label,
          itemClass:
            "rounded-xl border border-white/6 bg-black/15 px-4 py-3 text-sm font-bold text-white",
          dotClass:
            "mr-2 inline-block h-2 w-2 rounded-full bg-primary shadow-[0_0_12px_rgba(37,99,235,0.9)]",
        },
        ...summaryItem.bullets.map((text) => ({
          text,
          itemClass:
            "ml-4 flex items-start gap-3 text-sm leading-7 text-white/55",
          dotClass: "mt-3 h-1 w-1 shrink-0 rounded-full bg-white/45",
        })),
      ];
    },
  ),
}));
---

<Section
  text="Work Experience"
  href="experience"
  eyebrow="01 / Career"
  description="A progression from hands-on product engineering to frontend architecture, delivery ownership, and team leadership on enterprise SaaS systems."
>
  <div class="relative space-y-6 lg:space-y-8">
    {
      experienceItems.map(
        ({
          company,
          position,
          startDate,
          endDate,
          blocks,
          tags,
          displayIndex,
        }) => (
          <article class="group grid gap-4 lg:grid-cols-[13rem_minmax(0,1fr)]">
            <div class="relative hidden lg:block">
              <div class="absolute top-0 right-6 h-full w-px bg-white/8" />
              <div class="absolute top-7 right-[18px] h-4 w-4 rounded-full border-4 border-[#070b10] bg-primary shadow-[0_0_22px_rgba(37,99,235,0.7)] transition-transform duration-300 group-hover:scale-125" />
              <p class="pt-6 text-sm font-semibold text-white/45">
                {startDate}
              </p>
              <p class="mt-1 text-xs text-white/25">{endDate}</p>
            </div>

            <div class="relative overflow-hidden rounded-2xl border border-white/8 bg-[linear-gradient(135deg,rgba(255,255,255,0.065),rgba(255,255,255,0.025))] p-5 shadow-xl shadow-black/20 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/35 hover:shadow-[0_24px_70px_rgba(37,99,235,0.1)] sm:p-7">
              <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-primary/45 via-cyan-400/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" />

              <div class="mb-5 flex flex-col justify-between gap-3 sm:flex-row sm:items-start">
                <div class="min-w-0">
                  <div class="mb-3 inline-flex items-center rounded-full border border-white/8 bg-white/[0.035] px-3 py-1 text-[11px] font-bold tracking-[0.16em] text-white/35 uppercase lg:hidden">
                    {startDate} - {endDate}
                  </div>
                  <p class="text-xs font-bold tracking-[0.18em] text-primary uppercase">
                    {position}
                  </p>
                  <h3 class="mt-2 font-serif text-2xl font-semibold text-white md:text-3xl">
                    {company}
                  </h3>
                </div>
                <span class="hidden rounded-full border border-white/8 bg-white/[0.035] px-3 py-1 text-xs font-semibold text-white/35 sm:inline-flex">
                  {displayIndex}
                </span>
              </div>

              <ul class="list-none space-y-5">
                {blocks.map((block) => (
                  <li class={block.itemClass}>
                    <span class={block.dotClass} />
                    <span>{block.text}</span>
                  </li>
                ))}
              </ul>

              {tags && tags.length > 0 && (
                <div class="mt-6 flex flex-wrap gap-2 border-t border-white/6 pt-4">
                  {tags.map((tag) => (
                    <span class="rounded-full border border-white/8 bg-white/[0.035] px-3 py-1 text-xs font-semibold text-white/55 transition-colors group-hover:border-primary/20 group-hover:text-blue-300">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </article>
        ),
      )
    }
  </div>
</Section>
