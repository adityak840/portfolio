---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { ProjectProps } from "@types";
import { Icon } from "astro-icon/components";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

<Section
  text="Selected Projects"
  href="projects"
  eyebrow="06 / Builds"
  description="Hands-on products and platforms with real-time interaction, authentication, workflow design, and production-grade user experience."
>
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    {
      projects.map(
        ({ name, summary, image, linkPreview, linkSource, tags }, index) => (
          <article class="group flex min-h-full flex-col overflow-hidden rounded-2xl border border-white/8 bg-[#0c1219] shadow-xl shadow-black/20 transition-all duration-300 hover:-translate-y-1 hover:border-primary/30 hover:shadow-[0_26px_80px_rgba(37,99,235,0.12)]">
            <div class="relative h-56 w-full transform-gpu overflow-hidden bg-white/[0.025] transition-transform duration-700 group-hover:scale-[1.04] sm:h-64">
              <Image
                src={image}
                alt={name}
                width={800}
                height={500}
                class="h-full w-full object-cover object-top"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#0e141b] via-[#0e141b]/20 to-transparent" />

              <div class="absolute top-3 left-3 rounded-full border border-white/12 bg-black/60 px-3 py-1.5 text-xs font-bold text-white/70 backdrop-blur-md">
                Project {String(index + 1).padStart(2, "0")}
              </div>

              {linkPreview && (
                <a
                  href={linkPreview}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="absolute top-3 right-3 inline-flex items-center gap-1.5 rounded-full border border-white/15 bg-black/60 px-3 py-1.5 text-xs font-semibold text-white backdrop-blur-md transition hover:border-primary/60 hover:bg-primary/20"
                >
                  <span class="relative flex h-1.5 w-1.5">
                    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75" />
                    <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-400" />
                  </span>
                  Live
                </a>
              )}
            </div>

            <div class="flex flex-1 flex-col gap-5 p-6">
              <div>
                <h3 class="mb-3 font-serif text-2xl font-semibold text-white transition-colors duration-300 group-hover:text-blue-300">
                  {name}
                </h3>
                <p class="text-sm leading-7 text-white/58">{summary}</p>
              </div>

              {tags && tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {tags.map((tag) => (
                    <span class="rounded-full border border-white/8 bg-white/[0.045] px-2.5 py-1 text-xs font-semibold text-white/55">
                      {tag}
                    </span>
                  ))}
                </div>
              )}

              <div class="flex-1" />

              <div class="flex flex-wrap items-center gap-2 border-t border-white/5 pt-4">
                {linkSource &&
                  linkSource.map(({ label, url }) => (
                    <a
                      href={url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3.5 py-2 text-xs font-semibold text-white/75 transition-all duration-200 hover:border-white/20 hover:bg-white/10 hover:text-white"
                    >
                      <Icon name="mdi:github" class="h-3.5 w-3.5" />
                      {label}
                    </a>
                  ))}
                {linkPreview && (
                  <a
                    href={linkPreview}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 rounded-full border border-primary/30 bg-primary/10 px-3.5 py-2 text-xs font-semibold text-blue-300 transition-all duration-200 hover:border-primary/60 hover:bg-primary/20 hover:text-blue-200"
                  >
                    <Icon name="mdi:open-in-new" class="h-3.5 w-3.5" />
                    Live Preview
                  </a>
                )}
              </div>
            </div>
          </article>
        ),
      )
    }
  </div>
</Section>
