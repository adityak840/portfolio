---
import type { SkillProps } from "@types";
import Section from "./Section.astro";
import { Icon } from "astro-icon/components";
import SocketIO from "@icons/SocketIO.astro";
import Shadcn from "@icons/Shadcn.astro";

interface Props {
  skills: SkillProps[];
}

const { skills } = Astro.props;
---

<Section
  text="Technical Skills"
  href="skills"
  eyebrow="08 / Stack"
  description="A practical stack across frontend systems, backend services, cloud infrastructure, testing, data, and product delivery."
>
  <div class="grid gap-5 md:grid-cols-2">
    {
      skills.map((group) => (
        <article class="rounded-2xl border border-white/8 bg-white/[0.03] p-5 transition-all duration-300 hover:border-white/15 hover:bg-white/[0.045]">
          <p class="mb-4 text-xs font-bold tracking-[0.18em] text-white/35 uppercase">
            {group.category}
          </p>

          <ul class="flex flex-wrap gap-2">
            {group.items.map((skill) => (
              <li class="group flex items-center gap-2 rounded-full border border-white/8 bg-black/15 px-3.5 py-2 transition-all duration-200 hover:border-primary/35 hover:bg-primary/8 hover:shadow-[0_0_12px_rgba(37,99,235,0.12)]">
                <span class="flex h-4 w-4 items-center justify-center text-primary/70 transition-colors duration-200 group-hover:text-primary">
                  {skill.icon === "socketIo" ? (
                    <SocketIO class="h-3.5 w-3.5" />
                  ) : skill.icon === "shadcn" ? (
                    <Shadcn class="h-3.5 w-3.5" />
                  ) : (
                    <Icon
                      name={skill.icon}
                      class="h-3.5 w-3.5"
                      aria-hidden="true"
                    />
                  )}
                </span>

                <span class="text-sm font-semibold text-white/58 transition-colors duration-200 group-hover:text-white/90">
                  {skill.name}
                </span>
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</Section>
